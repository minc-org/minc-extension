{
  "name": "minc",
  "displayName": "MicroShift",
  "description": "Integration for MicroShift: run local Kubernetes clusters using container “nodes”",
  "version": "0.5.0-next",
  "icon": "icon.png",
  "publisher": "minc-org",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "podman-desktop": "^1.17.0"
  },
  "main": "./dist/main.cjs",
  "contributes": {
    "configuration": {
      "title": "MicroShift",
      "properties": {
        "microshift.cluster.form.description": {
          "type": "markdown",
          "scope": "KubernetesProviderConnectionFactory",
          "markdownDescription": "A MicroShift cluster is created using custom ports for routes."
        },
        "microshift.cluster.creation.http.port": {
          "type": "number",
          "default": 80,
          "scope": "KubernetesProviderConnectionFactory",
          "description": "HTTP Port for the routes"
        },
        "microshift.cluster.creation.https.port": {
          "type": "number",
          "default": 443,
          "scope": "KubernetesProviderConnectionFactory",
          "description": "HTTPS Port for the routes"
        }
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch --coverage",
    "test:e2e:setup": "playwright install chromium",
    "test:e2e": "cross-env DEBUG=pw:channel:response,pw:channel:event npm run test:e2e:setup && xvfb-maybe --auto-servernum --server-args='-screen 0 1280x960x24' -- npx playwright test",
    "format:check": "biome format",
    "format:fix": "biome format --write",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "watch": "vite build -w",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "inversify": "^7.11.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/compat": "^1.3.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.29.0",
    "@playwright/test": "^1.59.1",
    "@podman-desktop/api": "^1.26.2",
    "@podman-desktop/podman-extension-api": "^1.26.2",
    "@podman-desktop/tests-playwright": "next",
    "@types/node": "^22.19.17",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.5.0",
    "commitlint": "^20.5.3",
    "concurrently": "^9.2.1",
    "cross-env": "10.1.0",
    "eslint": "^9.29.0",
    "eslint-import-resolver-custom-alias": "^1.3.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-etc": "^2.0.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-redundant-undefined": "^1.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^61.0.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "8.0.10",
    "vitest": "^3.2.4",
    "xvfb-maybe": "^0.2.1"
  },
  "packageManager": "pnpm@10.6.3+sha512.bb45e34d50a9a76e858a95837301bfb6bd6d35aea2c5d52094fa497a467c43f5c440103ce2511e9e0a2f89c3d6071baac3358fc68ac6fb75e2ceb3d2736065e6",
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.4": "^3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
      "flatted@<3.4.0": ">=3.4.0",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "brace-expansion@<1.1.13": "~1.1.13"
    }
  }
}
